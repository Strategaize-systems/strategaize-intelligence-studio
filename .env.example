# ──────────────────────────────────────────────────────────────────────
# StrategAIze Intelligence Studio — V1 Marketing Launcher
# ENV-Konfiguration (siehe ARCHITECTURE.md A.11 + DEC-019)
# ──────────────────────────────────────────────────────────────────────

# ── Supabase (DEC-019: internal vs external URL strict trennen) ───────
# internal — Server, Worker (Docker-internes Kong)
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_SERVICE_ROLE_KEY=__set_in_secrets__
# external — Browser
NEXT_PUBLIC_SUPABASE_URL=https://is-api.strategaizetransition.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=__set_in_secrets__

# ── App-Host ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://is.strategaizetransition.com

# ── AWS Bedrock (DEC-002, eu-central-1 Frankfurt) ─────────────────────
BEDROCK_REGION=eu-central-1
AWS_ACCESS_KEY_ID=__set_in_secrets__
AWS_SECRET_ACCESS_KEY=__set_in_secrets__
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20251001-v1:0

# ── Feature-Flags (V1, siehe ARCHITECTURE.md A.11) ────────────────────
FEATURE_MARKETING_LAUNCHER_ENABLED=true
FEATURE_KNOWLEDGE_BACKBONE_ENABLED=false
FEATURE_PUBLISHING_ENABLED=false
BUSINESS_PIPELINE_PUSH_ENABLED=false

# ── Firecrawl (Self-Hosted, DEC-028) ──────────────────────────────────
FIRECRAWL_API_BASE_URL=http://firecrawl-internal:3002
FIRECRAWL_API_KEY=__set_in_secrets__

# ── Business-System Pipeline-Push (DEC-029, BL-027 Coordination) ──────
BUSINESS_API_BASE_URL=https://business-api.strategaizetransition.com
BUSINESS_API_TOKEN=__set_in_secrets__
BUSINESS_PIPELINE_NAME=Lead-Generierung
BUSINESS_STAGE_NAME=Neu

# ── Few-shot Performance-Loop (DEC-027) ───────────────────────────────
PERFORMANCE_FEWSHOT_N=2

# ── Lead Research Cost-Cap (Self-Host Soft-Limit) ─────────────────────
RESEARCH_RUN_COST_CAP_EUR=5

# ── Worker Polling (DEC-008) ──────────────────────────────────────────
AI_WORKER_POLL_MS=5000

# ── Test-DB (siehe coolify-test-setup.md) ─────────────────────────────
TEST_DATABASE_URL=postgresql://postgres:__set__@supabase-db-CONTAINER:5432/postgres
